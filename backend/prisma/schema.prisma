// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  FLEET_MANAGER
  DRIVER
}

enum FuelType {
  GASOLINE
  DIESEL
  LPG
  ELECTRIC
  HYBRID
}

enum VehicleStatus {
  ACTIVE
  GARAGE
  MAINTENANCE
  FAULTY
}

enum TaskStatus {
  ASSIGNED
  ON_THE_WAY
  COMPLETED
  CANCELLED
}

model Company {
  id        String   @id @default(cuid())
  name      String
  taxNumber String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  vehicles Vehicle[]
  tasks    Task[]
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  fullName     String
  email        String
  passwordHash String
  role         Role
  phone        String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedVehicle Vehicle[] @relation("DriverVehicle")
  assignedTasks   Task[]    @relation("DriverTask")

  @@unique([companyId, email])
  @@index([companyId, role])
}

model Vehicle {
  id          String        @id @default(cuid())
  companyId   String
  driverId    String?
  plateNumber String
  brand       String
  model       String
  year        Int
  fuelType    FuelType
  currentKm   Int           @default(0)
  status      VehicleStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driver       User?         @relation("DriverVehicle", fields: [driverId], references: [id], onDelete: SetNull)
  tasks        Task[]
  locationLogs LocationLog[]

  @@unique([companyId, plateNumber])
  @@index([companyId, status])
  @@index([driverId])
}

model Task {
  id                  String     @id @default(cuid())
  companyId           String
  vehicleId           String
  driverId            String
  title               String
  startLocation       String
  destinationLocation String
  estimatedMinutes    Int
  notes               String?
  status              TaskStatus @default(ASSIGNED)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver  User    @relation("DriverTask", fields: [driverId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([vehicleId])
  @@index([driverId, status])
}

model LocationLog {
  id         String   @id @default(cuid())
  vehicleId  String
  latitude   Float
  longitude  Float
  speed      Float
  heading    Float
  recordedAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, recordedAt])
  @@index([recordedAt])
}
